# Server
PORT=3000

# Gemini API (for virtual try-on)
GEMINI_API_KEY=your_gemini_api_key_here

# Shopbop API
# Client-ID assigned to this team — check the API docs PDF
SHOPBOP_CLIENT_ID=Shopbop-UW-Team1-2024
# Optional additional API key if required
SHOPBOP_API_KEY=

# AWS DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Admin analytics dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# Lambda try-on offload (optional — omit for local-only mode)
# Set TRYON_LAMBDA_NAME to enable Lambda mode; remove to use local generation
TRYON_LAMBDA_NAME=
# IAM role ARN for Lambda execution (only needed for deployment via npm run deploy:lambda)
TRYON_LAMBDA_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/shopbop-tryon-lambda-role
