# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Optional: Enable mock data for development
VITE_USE_MOCK_DATA=true

# Gemini API Key for Virtual Try-On (Nano Banana / Gemini 2.5 Flash Image)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Set to 'true' to use mock images instead of calling Gemini API (for development)
VITE_USE_MOCK_TRYON=false
